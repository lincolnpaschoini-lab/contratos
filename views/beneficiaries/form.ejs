<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Definição de beneficiários — Paschoini Advogados</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background: #f4f6fb;
      font-family: Arial, Helvetica, sans-serif;
      padding: 24px;
      color: #1a1f2e;
    }
    .wrap { max-width: 720px; margin: 0 auto; }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,.10);
      padding: 32px 36px;
      margin-bottom: 20px;
    }
    .header {
      background: #1a1f2e;
      border-radius: 12px 12px 0 0;
      margin: -32px -36px 24px;
      padding: 22px 36px;
    }
    .header p { margin: 0; color: #fff; font-size: 18px; font-weight: 700; }
    .header span { color: #94a3b8; font-size: 13px; }
    h2 { font-size: 17px; margin: 0 0 4px; }
    p.hint { color: #64748b; font-size: 13px; margin: 0 0 20px; }
    fieldset { border: none; padding: 0; margin: 0 0 20px; }
    label { font-size: 13px; font-weight: 600; color: #334155; display: block; margin-bottom: 4px; }
    .radio-row { display: flex; gap: 20px; margin-bottom: 4px; }
    .radio-row label { display: flex; align-items: center; gap: 6px; font-weight: 600; cursor: pointer; }
    input[type=text] {
      width: 100%; padding: 9px 12px; border: 1px solid #cbd5e1; border-radius: 6px;
      font-size: 14px; margin-bottom: 10px;
    }
    .section-title {
      font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
      color: #64748b; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin: 24px 0 12px;
    }
    .row-block {
      border: 1px solid #e2e8f0; border-radius: 8px; padding: 14px 16px; margin-bottom: 12px; position: relative;
    }
    .row-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 12px; }
    .row-grid.pj { grid-template-columns: 1fr 1fr 1fr; }
    .search-wrap { position: relative; margin-bottom: 10px; }
    .search-results {
      position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid #cbd5e1;
      border-radius: 6px; box-shadow: 0 4px 16px rgba(0,0,0,.12); max-height: 200px; overflow-y: auto; z-index: 10;
      display: none;
    }
    .search-results div { padding: 8px 12px; font-size: 13px; cursor: pointer; }
    .search-results div:hover { background: #f1f5f9; }
    .remove-btn {
      position: absolute; top: 10px; right: 12px;
      background: #fee2e2; border: 1px solid #fca5a5; color: #dc2626;
      border-radius: 6px; padding: 5px 12px;
      font-size: 12px; cursor: pointer; font-weight: 600;
      display: inline-flex; align-items: center; gap: 4px;
    }
    .remove-btn:hover { background: #fecaca; }
    .add-btn {
      background: #f1f5f9; border: 1px dashed #94a3b8; border-radius: 6px; padding: 8px 14px;
      font-size: 13px; font-weight: 600; color: #334155; cursor: pointer; margin-bottom: 8px;
    }
    .submit-btn {
      background: #0d6efd; color: #fff; border: none; border-radius: 7px; padding: 14px 32px;
      font-size: 15px; font-weight: 700; cursor: pointer; width: 100%; margin-top: 12px;
    }
    .submit-btn:hover { background: #0b5ed7; }
    .footer { margin-top: 20px; text-align: center; color: #94a3b8; font-size: 12px; }
    .row-block.row-error { border-color: #dc2626; background: #fef2f2; }
    .error-banner {
      display: none; background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b;
      border-radius: 6px; padding: 12px 16px; font-size: 13px; margin-bottom: 16px;
    }
    .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(15,23,42,.5);
      align-items: center; justify-content: center; z-index: 100; padding: 20px;
    }
    .modal-box {
      background: #fff; border-radius: 12px; max-width: 480px; width: 100%;
      padding: 28px 32px; box-shadow: 0 8px 32px rgba(0,0,0,.2);
    }
    .modal-box h3 { margin: 0 0 14px; font-size: 17px; }
    .modal-box ul { margin: 6px 0 14px; padding-left: 20px; font-size: 13px; }
    .modal-box p { font-size: 14px; margin: 0 0 8px; }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 18px; }
    .modal-actions button {
      padding: 10px 20px; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; border: none;
    }
    .modal-cancel { background: #f1f5f9; color: #334155; }
    .modal-confirm { background: #0d6efd; color: #fff; }
    .modal-confirm:disabled, .modal-cancel:disabled { opacity: .6; cursor: not-allowed; }
    .modal-loading { display: none; text-align: center; padding: 12px 0; }
    .modal-box.is-loading .modal-loading { display: block; }
    .modal-box.is-loading .modal-body-content,
    .modal-box.is-loading .modal-actions,
    .modal-box.is-loading > p { display: none; }
    .spinner {
      width: 32px; height: 32px; margin: 0 auto 14px;
      border: 3px solid #dbeafe; border-top-color: #0d6efd; border-radius: 50%;
      animation: spin .7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <div class="header">
      <p>Paschoini Advogados</p>
      <span>Definição de beneficiários</span>
    </div>

    <h2><%= customerName %></h2>
    <p class="hint">Tipo de serviço: <strong><%= tipoServico %></strong> — informe abaixo os beneficiários (pessoas físicas e/ou jurídicas) deste contrato, ou indique que não há beneficiários.</p>

    <form method="POST" action="/acoes/beneficiarios/<%= token %>" id="beneficiaryForm">

      <div class="error-banner" id="errorBanner"></div>

      <fieldset>
        <div class="radio-row">
          <label><input type="radio" name="none" value="false" checked id="radioHas" /> Cadastrar beneficiários</label>
          <label><input type="radio" name="none" value="true" id="radioNone" /> Não há beneficiários</label>
        </div>
      </fieldset>

      <div id="beneficiariesSection">

        <div class="section-title">Beneficiários — Pessoa Física</div>
        <div id="pfRows"></div>
        <button type="button" class="add-btn" id="addPf">+ Adicionar beneficiário PF</button>

        <div class="section-title">Beneficiários — Pessoa Jurídica</div>
        <div id="pjRows"></div>
        <button type="button" class="add-btn" id="addPj">+ Adicionar beneficiário PJ</button>

      </div>

      <button type="submit" class="submit-btn">Confirmar</button>
    </form>
  </div>
  <div class="footer">Paschoini Advogados &middot; Sistema interno de contratos</div>
</div>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal-box">
    <h3 class="modal-body-content">Confirmar envio</h3>
    <div id="modalBody" class="modal-body-content"></div>
    <p style="color:#64748b;font-size:12px;">Confira os dados antes de confirmar — essa ação não pode ser desfeita.</p>
    <div class="modal-actions">
      <button type="button" class="modal-cancel" id="modalCancel">Voltar e revisar</button>
      <button type="button" class="modal-confirm" id="modalConfirm">Confirmar e enviar</button>
    </div>
    <div class="modal-loading">
      <div class="spinner"></div>
      <div style="font-size:14px;font-weight:600;color:#1a1f2e;">Salvando informações...</div>
    </div>
  </div>
</div>

<template id="pfRowTemplate">
  <div class="row-block" data-row="pf">
    <button type="button" class="remove-btn">✕ Remover</button>
    <div class="search-wrap">
      <label>Buscar no Pipedrive (opcional)</label>
      <input type="text" class="pf-search" placeholder="Digite o nome..." autocomplete="off" />
      <div class="search-results"></div>
    </div>
    <div class="row-grid">
      <div>
        <label>Nome completo</label>
        <input type="text" class="pf-nome" name="" />
      </div>
      <div>
        <label>CPF</label>
        <input type="text" class="pf-cpf" name="" />
      </div>
    </div>
    <input type="hidden" class="pf-pdid" name="" />
  </div>
</template>

<template id="pjRowTemplate">
  <div class="row-block" data-row="pj">
    <button type="button" class="remove-btn">✕ Remover</button>
    <div class="search-wrap">
      <label>Buscar no Pipedrive (opcional)</label>
      <input type="text" class="pj-search" placeholder="Digite a razão social..." autocomplete="off" />
      <div class="search-results"></div>
    </div>
    <div class="row-grid pj">
      <div>
        <label>Razão social</label>
        <input type="text" class="pj-razao" name="" />
      </div>
      <div>
        <label>CNPJ</label>
        <input type="text" class="pj-cnpj" name="" />
      </div>
      <div>
        <label>Endereço</label>
        <input type="text" class="pj-endereco" name="" />
      </div>
    </div>
    <input type="hidden" class="pj-pdid" name="" />
  </div>
</template>

<script>
(function () {
  var TOKEN = <%- JSON.stringify(token) %>;
  var pfIndex = 0, pjIndex = 0;
  var pfRows = document.getElementById('pfRows');
  var pjRows = document.getElementById('pjRows');
  var section = document.getElementById('beneficiariesSection');

  function debounce(fn, wait) {
    var t;
    return function () {
      var args = arguments;
      clearTimeout(t);
      t = setTimeout(function () { fn.apply(null, args); }, wait);
    };
  }

  function addPfRow() {
    var tpl = document.getElementById('pfRowTemplate').content.cloneNode(true);
    var idx = pfIndex++;
    var block = tpl.querySelector('.row-block');
    tpl.querySelector('.pf-nome').name = 'pf[' + idx + '][nome]';
    tpl.querySelector('.pf-cpf').name = 'pf[' + idx + '][cpf]';
    tpl.querySelector('.pf-pdid').name = 'pf[' + idx + '][pipedrivePersonId]';
    wireSearch(tpl, 'pf', block);
    tpl.querySelector('.remove-btn').addEventListener('click', function () { block.remove(); });
    pfRows.appendChild(tpl);
  }

  function addPjRow() {
    var tpl = document.getElementById('pjRowTemplate').content.cloneNode(true);
    var idx = pjIndex++;
    var block = tpl.querySelector('.row-block');
    tpl.querySelector('.pj-razao').name = 'pj[' + idx + '][razaoSocial]';
    tpl.querySelector('.pj-cnpj').name = 'pj[' + idx + '][cnpj]';
    tpl.querySelector('.pj-endereco').name = 'pj[' + idx + '][endereco]';
    tpl.querySelector('.pj-pdid').name = 'pj[' + idx + '][pipedriveOrgId]';
    wireSearch(tpl, 'pj', block);
    tpl.querySelector('.remove-btn').addEventListener('click', function () { block.remove(); });
    pjRows.appendChild(tpl);
  }

  function wireSearch(tpl, type, block) {
    var input = tpl.querySelector(type === 'pf' ? '.pf-search' : '.pj-search');
    var resultsBox = tpl.querySelector('.search-results');

    var doSearch = debounce(function () {
      var term = input.value.trim();
      if (term.length < 2) { resultsBox.style.display = 'none'; return; }
      fetch('/acoes/beneficiarios/' + TOKEN + '/search?type=' + type + '&q=' + encodeURIComponent(term))
        .then(function (r) { return r.json(); })
        .then(function (json) {
          resultsBox.innerHTML = '';
          if (!json.success || !json.data || json.data.length === 0) { resultsBox.style.display = 'none'; return; }
          json.data.forEach(function (item) {
            var div = document.createElement('div');
            div.textContent = item.name;
            div.addEventListener('click', function () {
              selectRecord(type, item.id, block);
              resultsBox.style.display = 'none';
              input.value = item.name;
            });
            resultsBox.appendChild(div);
          });
          resultsBox.style.display = 'block';
        })
        .catch(function () { resultsBox.style.display = 'none'; });
    }, 350);

    input.addEventListener('input', doSearch);
    document.addEventListener('click', function (ev) {
      if (!block.contains(ev.target)) resultsBox.style.display = 'none';
    });
  }

  function selectRecord(type, id, block) {
    fetch('/acoes/beneficiarios/' + TOKEN + '/select?type=' + type + '&id=' + encodeURIComponent(id))
      .then(function (r) { return r.json(); })
      .then(function (json) {
        if (!json.success) return;
        if (type === 'pf') {
          block.querySelector('.pf-nome').value = json.data.nome || '';
          block.querySelector('.pf-cpf').value = json.data.cpf || '';
          block.querySelector('.pf-pdid').value = id;
        } else {
          block.querySelector('.pj-razao').value = json.data.razaoSocial || '';
          block.querySelector('.pj-cnpj').value = json.data.cnpj || '';
          block.querySelector('.pj-endereco').value = json.data.endereco || '';
          block.querySelector('.pj-pdid').value = id;
        }
      });
  }

  document.getElementById('addPf').addEventListener('click', addPfRow);
  document.getElementById('addPj').addEventListener('click', addPjRow);

  document.getElementById('radioHas').addEventListener('change', function () { section.style.display = ''; });
  document.getElementById('radioNone').addEventListener('change', function () { section.style.display = 'none'; });

  addPfRow();

  // ── Validação, bloqueio de Enter e confirmação antes do envio ────────────

  var form = document.getElementById('beneficiaryForm');
  var errorBanner = document.getElementById('errorBanner');
  var modalOverlay = document.getElementById('modalOverlay');
  var modalBody = document.getElementById('modalBody');

  // Enter em qualquer campo de texto não deve submeter o formulário
  // (evita envio acidental ao usar a busca do Pipedrive, por exemplo).
  form.addEventListener('keydown', function (ev) {
    if (ev.key === 'Enter' && ev.target.tagName === 'INPUT') {
      ev.preventDefault();
    }
  });

  function escapeHtml(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function validateAndCollect() {
    var errors = [];
    var isNone = document.getElementById('radioNone').checked;
    var summary = { none: isNone, pf: [], pj: [] };

    document.querySelectorAll('.row-block').forEach(function (b) { b.classList.remove('row-error'); });

    if (!isNone) {
      pfRows.querySelectorAll('.row-block').forEach(function (block) {
        var nome = block.querySelector('.pf-nome').value.trim();
        var cpf = block.querySelector('.pf-cpf').value.trim();
        var cpfDigits = cpf.replace(/\D/g, '');
        if (!nome && !cpf) return; // linha em branco — ignora
        if (!nome || cpfDigits.length !== 11) {
          block.classList.add('row-error');
          errors.push('Beneficiário PF: informe nome completo e um CPF válido (11 dígitos).');
          return;
        }
        summary.pf.push({ nome: nome, cpf: cpf });
      });

      pjRows.querySelectorAll('.row-block').forEach(function (block) {
        var razao = block.querySelector('.pj-razao').value.trim();
        var cnpj = block.querySelector('.pj-cnpj').value.trim();
        var cnpjDigits = cnpj.replace(/\D/g, '');
        if (!razao && !cnpj) return; // linha em branco — ignora
        if (!razao || cnpjDigits.length !== 14) {
          block.classList.add('row-error');
          errors.push('Beneficiário PJ: informe razão social e um CNPJ válido (14 dígitos).');
          return;
        }
        summary.pj.push({ razaoSocial: razao, cnpj: cnpj });
      });

      if (summary.pf.length === 0 && summary.pj.length === 0) {
        errors.push('Cadastre ao menos um beneficiário ou marque "Não há beneficiários".');
      }
    }

    return { errors: errors, summary: summary };
  }

  function showConfirmModal(summary) {
    var html = '';
    if (summary.none) {
      html = '<p>Confirma que <strong>não há beneficiários</strong> neste contrato?</p>';
    } else {
      if (summary.pf.length > 0) {
        html += '<p><strong>Pessoa Física</strong></p><ul>' + summary.pf.map(function (p) {
          return '<li>' + escapeHtml(p.nome) + ' — CPF ' + escapeHtml(p.cpf) + '</li>';
        }).join('') + '</ul>';
      }
      if (summary.pj.length > 0) {
        html += '<p><strong>Pessoa Jurídica</strong></p><ul>' + summary.pj.map(function (p) {
          return '<li>' + escapeHtml(p.razaoSocial) + ' — CNPJ ' + escapeHtml(p.cnpj) + '</li>';
        }).join('') + '</ul>';
      }
    }
    modalBody.innerHTML = html;
    modalOverlay.style.display = 'flex';
  }

  form.addEventListener('submit', function (ev) {
    ev.preventDefault();
    var result = validateAndCollect();
    if (result.errors.length > 0) {
      errorBanner.innerHTML = result.errors.map(function (m) { return '<div>• ' + escapeHtml(m) + '</div>'; }).join('');
      errorBanner.style.display = 'block';
      errorBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    errorBanner.style.display = 'none';
    showConfirmModal(result.summary);
  });

  document.getElementById('modalCancel').addEventListener('click', function () {
    modalOverlay.style.display = 'none';
  });
  var modalBox = document.querySelector('.modal-box');
  var modalConfirmBtn = document.getElementById('modalConfirm');
  var modalCancelBtn = document.getElementById('modalCancel');
  document.getElementById('modalConfirm').addEventListener('click', function () {
    if (modalBox.classList.contains('is-loading')) return; // evita duplo clique/duplo submit
    modalBox.classList.add('is-loading');
    modalConfirmBtn.disabled = true;
    modalCancelBtn.disabled = true;
    form.submit(); // chamada direta ao método nativo — não reemite o evento 'submit', evita loop
  });
})();
</script>
</body>
</html>
