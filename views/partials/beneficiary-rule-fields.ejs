<%
  // Locals esperados: rule (objeto com notifyEmails/active), hint (string opcional)
  const emailsFormatted = (rule.notifyEmails || '').split(',').map(function(e) { return e.trim(); }).filter(Boolean).join('\n');
%>

<div class="card">
  <div class="card-header py-2">
    <i class="bi bi-envelope-at me-2"></i><strong>Notificação de Beneficiários</strong>
  </div>
  <div class="card-body">
    <div class="mb-3">
      <label class="form-label small fw-semibold">
        E-mails que recebem o pedido de definição de beneficiários
      </label>
      <textarea name="notifyEmails" class="form-control font-monospace"
                rows="3"
                placeholder="email1@dominio.com&#10;email2@dominio.com"
      ><%= emailsFormatted %></textarea>
      <div class="form-text">Um e-mail por linha.</div>
    </div>
    <div class="mb-0">
      <label class="form-label small fw-semibold">Status</label>
      <select name="active" class="form-select">
        <option value="true" <%= rule.active ? 'selected' : '' %>>Ativo</option>
        <option value="false" <%= !rule.active ? 'selected' : '' %>>Inativo</option>
      </select>
    </div>
  </div>
  <% if (rule.updatedAt) { %>
  <div class="card-footer bg-transparent text-muted small">
    Atualizado em: <%= h.formatDate(rule.updatedAt) %>
  </div>
  <% } %>
</div>

<% if (typeof hint !== 'undefined' && hint) { %>
<p class="text-muted small mt-2 mb-0"><i class="bi bi-info-circle me-1"></i><%= hint %></p>
<% } %>

<div class="mt-3 d-flex justify-content-end">
  <button type="submit" class="btn btn-primary">
    <i class="bi bi-save me-1"></i>Salvar
  </button>
</div>
