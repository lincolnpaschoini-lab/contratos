<%
const stepIconMap = {
  PROPOSAL_ACCEPTED: 'bi-handshake',
  CONTRACT_PREPARATION: 'bi-pencil-square',
  CONTRACT_SIGNING: 'bi-pen',
  CONTRACT_REGISTRATION: 'bi-folder-check',
  CONTRACT_BILLING: 'bi-receipt',
};
const stepsOrdered = contract.steps.slice().sort((a, b) => a.stepOrder - b.stepOrder);
%>

<!-- Cabeçalho -->
<div class="page-header mb-0">
  <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
      <a href="/contracts" class="btn btn-sm btn-outline-secondary mb-2">
        <i class="bi bi-arrow-left me-1"></i>Voltar
      </a>
      <%
        const detailCompanyId = (contract.pipedriveDeal?.rawPayload)?.meta?.company_id ?? null;
        const detailCompany   = h.getCompanyInfo(detailCompanyId);
      %>
      <h2 class="page-title mb-1"><%= contract.customer.name %></h2>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <span class="text-muted small"><%= contract.pipedriveDeal.title %></span>
        <span class="badge bg-<%= detailCompany.css %><%= detailCompany.css === 'warning' ? ' text-dark' : '' %>">
          <i class="bi bi-building me-1"></i><%= detailCompany.name %>
        </span>
        <span class="badge bg-<%= h.CONTRACT_STATUS_CSS[contract.overallStatus] %> fs-6">
          <%= h.CONTRACT_STATUS_LABELS[contract.overallStatus] %>
        </span>
        <span class="badge bg-light text-dark border">
          <i class="bi bi-currency-dollar me-1"></i><%= h.formatCurrency(contract.pipedriveDeal.value) %>
        </span>
      </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#modalAssign">
        <i class="bi bi-person-gear me-1"></i>Atribuir
      </button>
      <% if (locals.currentUser && locals.currentUser.role === 'ADMIN') { %>
      <form method="POST" action="/contracts/<%= contract.id %>/sync-pipedrive" class="d-inline">
        <button type="submit" class="btn btn-sm btn-outline-info" title="Re-buscar dados da empresa e contato no Pipedrive">
          <i class="bi bi-arrow-repeat me-1"></i>Sincronizar Pipedrive
        </button>
      </form>
      <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#modalDelete">
        <i class="bi bi-trash me-1"></i>Excluir
      </button>
      <% } %>
    </div>
  </div>
</div>

<!-- Info cards -->
<%
  const personExtracted = contract.customer.pipedrivePersonRaw && contract.customer.pipedrivePersonRaw._extracted
    ? contract.customer.pipedrivePersonRaw._extracted : null;
  const orgExtracted = contract.customer.pipedriveOrgRaw && contract.customer.pipedriveOrgRaw._extracted
    ? contract.customer.pipedriveOrgRaw._extracted : null;
  const dealExtracted = contract.pipedriveDeal && contract.pipedriveDeal.rawPayload && contract.pipedriveDeal.rawPayload._extracted
    ? contract.pipedriveDeal.rawPayload._extracted : null;
  const tipoServico = (contract.pipedriveDeal && contract.pipedriveDeal.tipoServico) ? contract.pipedriveDeal.tipoServico : '';
  const isPF = tipoServico.includes('PF');
%>
<div class="row g-3 mb-4 mt-2">

  <!-- Dados da Empresa (PJ) — só exibe se há org vinculada -->
  <% if (!isPF || contract.customer.pipedriveOrgId) { %>
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-building me-2"></i>Dados da Empresa</span>
        <% if (contract.customer.pipedriveOrgId) { %>
        <span class="badge bg-light text-dark border small">
          <i class="bi bi-diagram-3 me-1"></i>Org ID: <%= contract.customer.pipedriveOrgId %>
        </span>
        <% } %>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12 col-md-4">
            <div class="small text-muted">Razão Social</div>
            <div class="fw-semibold"><%= (orgExtracted && orgExtracted.razaoSocial) ? orgExtracted.razaoSocial : contract.customer.name %></div>
          </div>
          <%- ((orgExtracted && orgExtracted.cnpj) || contract.customer.document) ? `
          <div class="col-12 col-md-4">
            <div class="small text-muted">CNPJ</div>
            <div class="fw-semibold">${(orgExtracted && orgExtracted.cnpj) ? orgExtracted.cnpj : contract.customer.document}</div>
          </div>` : '' %>
          <% if (orgExtracted && orgExtracted.dataFundacao) { %>
          <div class="col-12 col-md-4">
            <div class="small text-muted">Data de Fundação</div>
            <div class="fw-semibold"><%= orgExtracted.dataFundacao %></div>
          </div>
          <% } %>
          <%
            const orgEmailDisplay = (orgExtracted && orgExtracted.email) ? orgExtracted.email : contract.customer.email;
          %>
          <% if (orgEmailDisplay) { %>
          <div class="col-12 col-md-4">
            <div class="small text-muted">E-mail</div>
            <div><a href="mailto:<%= orgEmailDisplay %>"><%= orgEmailDisplay %></a></div>
          </div>
          <% } %>
          <%
            const orgPhoneDisplay = (orgExtracted && orgExtracted.telefone) ? orgExtracted.telefone : contract.customer.phone;
          %>
          <% if (orgPhoneDisplay) { %>
          <div class="col-12 col-md-4">
            <div class="small text-muted">Telefone</div>
            <div><%= orgPhoneDisplay %></div>
          </div>
          <% } %>
          <%
            const orgEnderecoDisplay = (orgExtracted && orgExtracted.endereco) ? orgExtracted.endereco : contract.customer.address;
          %>
          <% if (orgEnderecoDisplay || contract.customer.city) { %>
          <div class="col-12 col-md-8">
            <div class="small text-muted">Endereço</div>
            <div>
              <%= orgEnderecoDisplay || '' %>
              <% if (contract.customer.city) { %><span class="text-muted"> — <%= contract.customer.city %><% if (contract.customer.state) { %>/<%= contract.customer.state %><% } %></span><% } %>
              <% if (contract.customer.zipCode) { %><span class="text-muted"> CEP: <%= contract.customer.zipCode %></span><% } %>
            </div>
          </div>
          <% } %>
        </div>

        <%
          const orgRaw = contract.customer.pipedriveOrgRaw;
          const labeled = orgRaw && orgRaw._labeled ? orgRaw._labeled : null;
          const hasUnmapped = labeled && Object.keys(labeled).length > 0;
        %>
        <% if (locals.currentUser?.role === 'ADMIN' && hasUnmapped) { %>
        <div class="mt-3">
          <button class="btn btn-xs btn-outline-secondary" type="button"
                  data-bs-toggle="collapse" data-bs-target="#collapsePipedriveFields">
            <i class="bi bi-database me-1"></i>Ver todos os campos do Pipedrive
          </button>
          <div class="collapse mt-2" id="collapsePipedriveFields">
            <div class="p-3 bg-light rounded border small">
              <div class="fw-semibold mb-2 text-muted">Campos disponíveis na organização Pipedrive:</div>
              <div class="row g-2">
                <% Object.entries(labeled).forEach(([label, value]) => { %>
                <% if (value && value !== 'null' && value !== 'undefined' && String(value).trim() !== '') { %>
                <div class="col-12 col-md-6 col-lg-4">
                  <span class="text-muted"><%= label %>:</span>
                  <span class="fw-semibold ms-1"><%= value %></span>
                </div>
                <% } %>
                <% }); %>
              </div>
            </div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Contratante PF (pessoa física) ou Representante (PJ) -->
  <% const hasPersonData = contract.customer.contactName || contract.customer.contactEmail || contract.customer.pipedrivePersonId || personExtracted; %>
  <% if (hasPersonData) { %>
  <div class="col-12 col-md-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-person me-2"></i><%= isPF ? 'Contratante PF' : 'Representante' %></span>
        <% if (contract.customer.pipedrivePersonId) { %>
        <span class="badge bg-light text-dark border small">ID: <%= contract.customer.pipedrivePersonId %></span>
        <% } %>
      </div>
      <div class="card-body">
        <div class="row g-2">
          <% const pName = (personExtracted && personExtracted.nome) ? personExtracted.nome : contract.customer.contactName; %>
          <div class="col-12 col-md-6">
            <div class="small text-muted">Nome</div>
            <div class="fw-semibold"><%= pName || '—' %></div>
          </div>
          <div class="col-12 col-md-6">
            <div class="small text-muted">CPF</div>
            <div><%= (personExtracted && personExtracted.cpf) || '—' %></div>
          </div>
          <div class="col-12 col-md-6">
            <div class="small text-muted">RG</div>
            <div><%= (personExtracted && personExtracted.rg) || '—' %></div>
          </div>
          <div class="col-12 col-md-6">
            <div class="small text-muted">Data de Expedição</div>
            <div><%= (personExtracted && personExtracted.dataExpDoc) || '—' %></div>
          </div>
          <div class="col-12 col-md-6">
            <div class="small text-muted">Data de Nascimento</div>
            <div><%= (personExtracted && personExtracted.dataNascimento) || '—' %></div>
          </div>
          <div class="col-12 col-md-6">
            <div class="small text-muted">Estado Civil</div>
            <div><%= (personExtracted && personExtracted.estadoCivil) || '—' %></div>
          </div>
          <div class="col-12 col-md-6">
            <div class="small text-muted">Nacionalidade</div>
            <div><%= (personExtracted && personExtracted.nacionalidade) || '—' %></div>
          </div>
          <div class="col-12 col-md-6">
            <div class="small text-muted">Profissão</div>
            <div><%= (personExtracted && personExtracted.profissao) || '—' %></div>
          </div>
          <% const pEmail = (personExtracted && personExtracted.email) ? personExtracted.email : contract.customer.contactEmail; %>
          <div class="col-12 col-md-6">
            <div class="small text-muted">E-mail</div>
            <div>
              <% if (pEmail) { %><a href="mailto:<%= pEmail %>"><%= pEmail %></a><% } else { %>—<% } %>
            </div>
          </div>
          <% const pPhone = (personExtracted && personExtracted.telefone) ? personExtracted.telefone : contract.customer.contactPhone; %>
          <div class="col-12 col-md-6">
            <div class="small text-muted">Telefone</div>
            <div><%= pPhone || '—' %></div>
          </div>
          <div class="col-12">
            <div class="small text-muted">Endereço</div>
            <div><%= (personExtracted && personExtracted.enderecoCompleto) || '—' %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Dados do Contrato -->
  <div class="col-12 col-md-<%= hasPersonData ? '6' : '12' %>">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-file-earmark-text me-2"></i>Dados do Contrato</div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-6">
            <div class="small text-muted">Responsável interno</div>
            <div class="fw-semibold"><%= contract.assignedUser?.name || '—' %></div>
          </div>
          <div class="col-6">
            <div class="small text-muted">Proposta aceita em</div>
            <div class="fw-semibold"><%= h.formatDate(contract.proposalAcceptedAt) %></div>
          </div>
          <div class="col-6">
            <div class="small text-muted">Deal Pipedrive</div>
            <div class="fw-semibold small"><%= contract.pipedriveDeal.externalDealId %></div>
          </div>
          <div class="col-6">
            <div class="small text-muted">Valor</div>
            <div class="fw-semibold text-primary"><%= h.formatCurrency(contract.pipedriveDeal.value) %></div>
          </div>
          <% if (contract.pipedriveDeal.tipoServico) { %>
          <div class="col-12">
            <div class="small text-muted">Tipo de Serviço</div>
            <div class="fw-semibold">
              <span class="badge bg-info-subtle text-info border border-info-subtle px-2 py-1">
                <i class="bi bi-file-earmark-text me-1"></i><%= contract.pipedriveDeal.tipoServico %>
              </span>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Condições Contratuais (campos customizados do Deal) — sempre exibido -->
  <div class="col-12">
    <div class="card">
      <div class="card-header"><i class="bi bi-clipboard-check me-2"></i>Condições Contratuais</div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-12 col-md-3">
            <div class="small text-muted">Vigência</div>
            <div class="fw-semibold mt-1">
              <% if (dealExtracted && dealExtracted.vigencia === 'Determinada') { %>
              <span class="badge bg-warning text-dark"><i class="bi bi-calendar-range me-1"></i>Determinada</span>
              <% } else if (dealExtracted && dealExtracted.vigencia === 'Indeterminada') { %>
              <span class="badge bg-secondary"><i class="bi bi-infinity me-1"></i>Indeterminada</span>
              <% } else { %>
              <span class="text-muted">—</span>
              <% } %>
            </div>
          </div>
          <div class="col-12 col-md-3">
            <div class="small text-muted">Duração</div>
            <div class="fw-semibold"><%= (dealExtracted && dealExtracted.duracaoVigencia) || '—' %></div>
          </div>
          <div class="col-12 col-md-3">
            <div class="small text-muted">Término</div>
            <div class="fw-semibold"><%= (dealExtracted && dealExtracted.terminoVigencia) || '—' %></div>
          </div>
          <div class="col-12 col-md-3">
            <div class="small text-muted">Área do Contrato</div>
            <div class="fw-semibold"><%= (dealExtracted && dealExtracted.areaContrato) || '—' %></div>
          </div>
          <div class="col-12">
            <div class="small text-muted">Descrição do Contrato</div>
            <div class="text-break"><%= (dealExtracted && dealExtracted.descricaoContrato) || '—' %></div>
          </div>
          <div class="col-12">
            <hr class="my-1">
            <div class="small fw-semibold text-muted mb-2">Honorários</div>
            <div class="row g-2">
              <div class="col-12 col-md-3">
                <div class="small text-muted">Honorário Fixo</div>
                <% if (dealExtracted && dealExtracted.honorarioFixo === 'Sim') { %>
                <span class="text-success fw-semibold"><i class="bi bi-check-circle-fill me-1"></i>Sim</span>
                <% } else if (dealExtracted && dealExtracted.honorarioFixo === 'Não') { %>
                <span class="text-muted"><i class="bi bi-x-circle me-1"></i>Não</span>
                <% } else { %>
                <span class="text-muted">—</span>
                <% } %>
              </div>
              <div class="col-12 col-md-9">
                <div class="small text-muted">Detalhes do Honorário</div>
                <div><%= (dealExtracted && dealExtracted.detalhesHonorarioFixo) || '—' %></div>
              </div>
              <div class="col-12 col-md-3">
                <div class="small text-muted">Ad Exitum</div>
                <% if (dealExtracted && dealExtracted.adExitum === 'Sim') { %>
                <span class="text-success fw-semibold"><i class="bi bi-check-circle-fill me-1"></i>Sim</span>
                <% } else if (dealExtracted && dealExtracted.adExitum === 'Não') { %>
                <span class="text-muted"><i class="bi bi-x-circle me-1"></i>Não</span>
                <% } else { %>
                <span class="text-muted">—</span>
                <% } %>
              </div>
              <div class="col-12 col-md-3">
                <div class="small text-muted">Porcentagem Ad Exitum</div>
                <div class="fw-semibold"><%= (dealExtracted && dealExtracted.porcentagemAdExitum) || '—' %></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Timeline das etapas -->
<div class="card mb-4">
  <div class="card-header"><i class="bi bi-diagram-3 me-2"></i>Linha do Tempo</div>
  <div class="card-body">
    <div class="timeline-container">
      <% stepsOrdered.forEach((step, idx) => {
        const isLast = idx === stepsOrdered.length - 1;
        const isOverdue = step.dueAt && new Date(step.dueAt) < new Date() && step.status !== 'COMPLETED';
        const statusClass = step.status === 'COMPLETED' ? 'success' :
                            step.status === 'DELAYED' ? 'danger' :
                            step.status === 'IN_PROGRESS' ? 'warning' : 'secondary';
        const canStart = step.status === 'PENDING' && (idx === 0 || stepsOrdered[idx-1]?.status === 'COMPLETED');
        const canComplete = step.status === 'IN_PROGRESS' || step.status === 'DELAYED';
      %>
      <div class="timeline-step <%= step.status.toLowerCase() %> <%= isOverdue ? 'overdue' : '' %>">
        <div class="timeline-connector <% if (step.status === 'COMPLETED') { %>completed<% } %>"></div>
        <div class="timeline-node bg-<%= statusClass %>">
          <% if (step.status === 'COMPLETED') { %>
            <i class="bi bi-check-lg text-white"></i>
          <% } else if (step.status === 'DELAYED') { %>
            <i class="bi bi-exclamation text-white"></i>
          <% } else if (step.status === 'IN_PROGRESS') { %>
            <i class="bi bi-hourglass-split text-white"></i>
          <% } else { %>
            <i class="bi bi-circle text-white"></i>
          <% } %>
        </div>
        <div class="timeline-content">
          <div class="timeline-title">
            <i class="bi <%= stepIconMap[step.stepName] %> me-1"></i>
            <%= h.STEP_LABELS[step.stepName] %>
            <span class="badge bg-<%= statusClass %> ms-1 small"><%= h.STEP_STATUS_LABELS[step.status] %></span>
          </div>

          <%
            const pipedriveInitHistory = step.histories && step.histories.find(function(h2) {
              return h2.metadata && h2.metadata.pipedriveUser;
            });
            const pipedriveInitUser = pipedriveInitHistory && pipedriveInitHistory.metadata && pipedriveInitHistory.metadata.pipedriveUser;
          %>
          <div class="timeline-meta">
            <% if (step.startedAt) { %>
            <span><i class="bi bi-play-circle me-1"></i>Iniciado: <%= h.formatDateTime(step.startedAt) %></span>
            <% } %>
            <% if (step.completedAt) { %>
            <span class="text-success"><i class="bi bi-check-circle me-1"></i>Concluído: <%= h.formatDateTime(step.completedAt) %></span>
            <% } %>
            <% if (step.dueAt && step.status !== 'COMPLETED') { %>
            <span class="<%= isOverdue ? 'text-danger fw-semibold' : '' %>">
              <i class="bi bi-calendar-event me-1"></i>Prazo: <%= h.formatDate(step.dueAt) %>
              <% if (isOverdue) { %><span class="badge bg-danger ms-1">ATRASADO</span><% } %>
            </span>
            <% } %>
            <% if (step.assignedUser) { %>
            <span><i class="bi bi-person me-1"></i><%= step.assignedUser.name %></span>
            <% } %>
            <% if (pipedriveInitUser) { %>
            <span class="text-muted"><i class="bi bi-diagram-3 me-1"></i>Pipedrive: <strong><%= pipedriveInitUser.name %></strong></span>
            <% } %>
          </div>

          <!-- Ações -->
          <% if (canStart || canComplete || step.stepName === 'CONTRACT_REGISTRATION') { %>
          <div class="timeline-actions mt-2 d-flex gap-2 flex-wrap">
            <% if (canStart) { %>
            <form method="POST" action="/contracts/<%= contract.id %>/steps/<%= step.id %>/start" class="d-inline">
              <button type="submit" class="btn btn-sm btn-warning">
                <i class="bi bi-play-fill me-1"></i>Iniciar Etapa
              </button>
            </form>
            <% } %>
            <% if (canComplete) { %>
            <button class="btn btn-sm btn-success" data-bs-toggle="modal"
                    data-bs-target="#modalComplete" data-step-id="<%= step.id %>"
                    data-step-name="<%= h.STEP_LABELS[step.stepName] %>">
              <i class="bi bi-check-lg me-1"></i>Concluir
            </button>
            <% } %>
            <% if (step.stepName === 'CONTRACT_REGISTRATION') { %>
            <form method="POST" action="/contracts/<%= contract.id %>/send-registration-email" class="d-inline">
              <button type="submit" class="btn btn-sm btn-outline-primary" title="Reenvia o e-mail com o botão de confirmação de cadastro">
                <i class="bi bi-envelope me-1"></i>Enviar E-mail
              </button>
            </form>
            <% } %>
            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse"
                    data-bs-target="#stepDetail<%= step.id %>">
              <i class="bi bi-chat-text me-1"></i>Detalhes
            </button>
          </div>

          <!-- Painel expandível com notas e histórico -->
          <div class="collapse mt-2" id="stepDetail<%= step.id %>">
            <div class="step-detail-panel">
              <!-- Observações -->
              <form method="POST" action="/contracts/<%= contract.id %>/steps/<%= step.id %>/notes" class="mb-3">
                <label class="form-label small fw-semibold">Observações</label>
                <textarea name="notes" class="form-control form-control-sm" rows="2"
                          placeholder="Adicione observações sobre esta etapa..."><%= step.notes || '' %></textarea>
                <button type="submit" class="btn btn-sm btn-outline-primary mt-1">Salvar Obs.</button>
              </form>

              <!-- Atribuir responsável à etapa -->
              <form method="POST" action="/contracts/<%= contract.id %>/steps/<%= step.id %>/assign" class="mb-3 d-flex gap-2">
                <select name="assignedUserId" class="form-select form-select-sm">
                  <option value="">— Atribuir responsável —</option>
                  <% users.forEach(u => { %>
                  <option value="<%= u.id %>" <%= step.assignedUser?.id === u.id ? 'selected' : '' %>><%= u.name %></option>
                  <% }); %>
                </select>
                <button type="submit" class="btn btn-sm btn-outline-secondary">Salvar</button>
              </form>

              <!-- Histórico -->
              <% if (step.histories && step.histories.length > 0) { %>
              <div class="small fw-semibold mb-1">Histórico</div>
              <div class="history-list">
                <% step.histories.forEach(h2 => { %>
                <div class="history-item">
                  <div class="d-flex align-items-center gap-2">
                    <% if (h2.fromStatus) { %>
                    <span class="badge bg-secondary small"><%= h.STEP_STATUS_LABELS[h2.fromStatus] || h2.fromStatus %></span>
                    <i class="bi bi-arrow-right text-muted small"></i>
                    <% } %>
                    <span class="badge bg-primary small"><%= h.STEP_STATUS_LABELS[h2.toStatus] || h2.toStatus %></span>
                    <span class="text-muted small ms-auto"><%= h.formatDateTime(h2.createdAt) %></span>
                  </div>
                  <% if (h2.changeReason) { %>
                  <div class="text-muted small mt-1"><i class="bi bi-chat-left-text me-1"></i><%= h2.changeReason %></div>
                  <% } %>
                  <% if (h2.changedByUser) { %>
                  <div class="text-muted small"><i class="bi bi-person me-1"></i><%= h2.changedByUser.name %></div>
                  <% } else if (h2.metadata && h2.metadata.pipedriveUser) { %>
                  <div class="text-muted small"><i class="bi bi-diagram-3 me-1"></i>Pipedrive: <%= h2.metadata.pipedriveUser.name %></div>
                  <% } %>
                </div>
                <% }); %>
              </div>
              <% } %>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- Envio manual para Clicksign (quando está em Assinatura mas sem envelope) -->
<% if (contract.currentStep === 'CONTRACT_SIGNING' && (!contract.clicksignDocs || contract.clicksignDocs.length === 0)) { %>
<div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
  <i class="bi bi-exclamation-triangle fs-4"></i>
  <div class="flex-grow-1">
    <div class="fw-semibold">Contrato em Assinatura sem envelope Clicksign</div>
    <div class="small text-muted">O envio automático pode ter falhado ou sido ignorado. Você pode disparar manualmente.</div>
  </div>
  <form method="POST" action="/contracts/<%= contract.id %>/clicksign-send">
    <button type="submit" class="btn btn-warning">
      <i class="bi bi-send me-1"></i>Enviar para Clicksign
    </button>
  </form>
</div>
<% } %>

<!-- Integração Clicksign -->
<% if (contract.clicksignDocs && contract.clicksignDocs.length > 0) { %>
<%
  const csDoc = contract.clicksignDocs[0];
  const csStatusMap = { draft: 'Rascunho', running: 'Aguardando assinaturas', closed: 'Assinado', canceled: 'Cancelado' };
  const csStatusCss  = { draft: 'secondary', running: 'warning', closed: 'success', canceled: 'danger' };
  const csLabel = csStatusMap[csDoc.status] || csDoc.status;
  const csCss   = csStatusCss[csDoc.status] || 'secondary';
  const clicksignBaseUrl = process.env.CLICKSIGN_API_URL || 'https://sandbox.clicksign.com';
  const envelopeUrl = csDoc.externalEnvelopeId
    ? clicksignBaseUrl.replace('/api/v3','').replace(/\/$/, '') + '/envelopes/' + csDoc.externalEnvelopeId
    : null;
%>
<div class="card mb-4" id="clicksign-card" data-clicksign-running="<%= csDoc.status === 'running' ? 'true' : 'false' %>" data-contract-id="<%= contract.id %>">
  <div class="card-header d-flex align-items-center justify-content-between">
    <span><i class="bi bi-pen me-2"></i>Assinatura Clicksign</span>
    <div class="d-flex gap-2">
      <% if (envelopeUrl) { %>
      <a href="<%= envelopeUrl %>" target="_blank" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-box-arrow-up-right me-1"></i>Ver no Clicksign
      </a>
      <% } %>
      <form method="POST" action="/contracts/<%= contract.id %>/clicksign-refresh" class="d-inline">
        <button type="submit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-arrow-repeat me-1"></i>Atualizar status
        </button>
      </form>
    </div>
  </div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-6 col-md-3">
        <div class="small text-muted">Status</div>
        <span class="badge bg-<%= csCss %> fs-6"><%= csLabel %></span>
      </div>
      <% if (csDoc.sentAt) { %>
      <div class="col-6 col-md-3">
        <div class="small text-muted">Enviado em</div>
        <div class="fw-semibold"><%= h.formatDateTime(csDoc.sentAt) %></div>
      </div>
      <% } %>
      <% if (csDoc.signedAt) { %>
      <div class="col-6 col-md-3">
        <div class="small text-muted">Assinado em</div>
        <div class="fw-semibold text-success"><%= h.formatDateTime(csDoc.signedAt) %></div>
      </div>
      <% } %>
      <% if (csDoc.externalEnvelopeId) { %>
      <div class="col-12 col-md-6">
        <div class="small text-muted">ID do Envelope</div>
        <div class="fw-semibold small text-break"><%= csDoc.externalEnvelopeId %></div>
      </div>
      <% } %>
    </div>

    <%
      const signers = csDoc.rawPayload && csDoc.rawPayload.signers ? csDoc.rawPayload.signers : [];
    %>
    <% if (signers.length > 0) { %>
    <hr class="my-3">
    <div class="small fw-semibold text-muted mb-2">Signatários</div>
    <div class="d-flex flex-column gap-2" id="clicksign-signers">
      <% signers.forEach(function(signer) {
        const signed = signer.status === 'signed' || signer.signed_at;
      %>
      <div class="d-flex align-items-center gap-2" data-signer-email="<%= signer.email %>">
        <i class="bi <%= signed ? 'bi-check-circle-fill text-success' : 'bi-arrow-clockwise text-warning signer-spin' %> fs-5 signer-icon"></i>
        <div>
          <div class="fw-semibold small"><%= signer.name %></div>
          <div class="text-muted" style="font-size:.8rem"><%= signer.email %></div>
        </div>
        <div class="ms-auto text-end">
          <span class="badge <%= signed ? 'bg-success' : 'bg-warning text-dark' %> signer-status-badge">
            <%= signed ? 'Assinado' : 'Pendente' %>
          </span>
          <div class="text-muted signer-date" style="font-size:.75rem">
            <%= signer.signed_at ? h.formatDateTime(signer.signed_at) : '' %>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>
<% } %>

<!-- Modal Excluir Contrato -->
<% if (locals.currentUser && locals.currentUser.role === 'ADMIN') { %>
<div class="modal fade" id="modalDelete" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/contracts/<%= contract.id %>/delete">
      <div class="modal-content">
        <div class="modal-header bg-danger text-white">
          <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Excluir Contrato</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p>Tem certeza que deseja excluir o contrato de <strong><%= contract.customer.name %></strong>?</p>
          <div class="alert alert-warning py-2 small">
            <i class="bi bi-info-circle me-1"></i>
            Esta ação é <strong>irreversível</strong>. Todas as etapas, histórico e documentos vinculados serão removidos.<br/>
            O deal poderá ser reimportado pelo webhook do Pipedrive se movido novamente para "Proposta aceita".
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirmar Exclusão</button>
        </div>
      </div>
    </form>
  </div>
</div>
<% } %>

<!-- Modal Concluir Etapa -->
<div class="modal fade" id="modalComplete" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" id="formComplete">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-check-circle me-2"></i>Concluir Etapa</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p>Confirma a conclusão de <strong id="completeStepName"></strong>?</p>
          <div class="mb-3">
            <label class="form-label">Observação (opcional)</label>
            <textarea name="notes" class="form-control" rows="3" placeholder="Adicione uma observação..."></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Confirmar Conclusão</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Modal Atribuir Responsável (contrato) -->
<div class="modal fade" id="modalAssign" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/contracts/<%= contract.id %>/assign">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-person-gear me-2"></i>Atribuir Responsável</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <select name="assignedUserId" class="form-select">
            <option value="">— Selecione —</option>
            <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= contract.assignedUser?.id === u.id ? 'selected' : '' %>><%= u.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
// Configura o modal de conclusão com o ID da etapa
document.getElementById('modalComplete')?.addEventListener('show.bs.modal', function(e) {
  const btn = e.relatedTarget;
  const stepId = btn.dataset.stepId;
  const stepName = btn.dataset.stepName;
  document.getElementById('formComplete').action = '/contracts/<%= contract.id %>/steps/' + stepId + '/complete';
  document.getElementById('completeStepName').textContent = stepName;
});

// ── Utilitários ─────────────────────────────────────────────────────────────
function formatBRT(isoString) {
  if (!isoString) return '';
  try {
    return new Intl.DateTimeFormat('pt-BR', {
      timeZone: 'America/Sao_Paulo',
      day: '2-digit', month: '2-digit', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
    }).format(new Date(isoString));
  } catch (e) { return isoString; }
}

// ── Polling de atualizações em tempo real ───────────────────────────────────
(function() {
  const CONTRACT_ID    = '<%= contract.id %>';
  const INITIAL_STEP   = '<%= contract.currentStep %>';
  const INITIAL_STATUS = '<%= contract.overallStatus %>';

  // Polling de etapa/status global — recarrega a página se algo mudar
  function pollStepStatus() {
    fetch('/contracts/' + CONTRACT_ID + '/step-status', { headers: { Accept: 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.currentStep !== INITIAL_STEP || data.overallStatus !== INITIAL_STATUS) {
          location.reload();
        }
      })
      .catch(function() {});
  }

  // Polling de signatários Clicksign — consulta API live e atualiza DOM
  var csCard = document.getElementById('clicksign-card');
  function pollClicksignStatus() {
    fetch('/contracts/' + CONTRACT_ID + '/clicksign-status', { headers: { Accept: 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.hasClicksign) return;

        var signers = data.signers || [];
        signers.forEach(function(signer) {
          var row = document.querySelector('[data-signer-email="' + signer.email + '"]');
          if (!row) return;
          var signed = signer.status === 'signed' || signer.signed_at;
          var icon   = row.querySelector('.signer-icon');
          var badge  = row.querySelector('.signer-status-badge');
          var dateEl = row.querySelector('.signer-date');
          if (icon) {
            icon.className = 'bi fs-5 signer-icon ' +
              (signed ? 'bi-check-circle-fill text-success' : 'bi-arrow-clockwise text-warning signer-spin');
          }
          if (badge) {
            badge.className = 'badge signer-status-badge ' + (signed ? 'bg-success' : 'bg-warning text-dark');
            badge.textContent = signed ? 'Assinado' : 'Pendente';
          }
          if (dateEl) {
            dateEl.textContent = signed ? formatBRT(signer.signed_at) : '';
          }
        });

        // Se envelope fechou (todos assinaram), recarrega para atualizar linha do tempo
        if (csCard) {
          var wasRunning = csCard.dataset.clicksignRunning === 'true';
          var isRunning  = data.status === 'running';
          if (wasRunning && !isRunning) {
            location.reload();
          }
        }
      })
      .catch(function() {});
  }

  var stepInterval = setInterval(pollStepStatus, 10000);
  var csInterval   = null;
  if (csCard && csCard.dataset.clicksignRunning === 'true') {
    // 15s para não sobrecarregar a API do Clicksign
    csInterval = setInterval(pollClicksignStatus, 15000);
  }

  window.addEventListener('beforeunload', function() {
    clearInterval(stepInterval);
    if (csInterval) clearInterval(csInterval);
  });
})();
</script>
