<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2">
  <div>
    <h2 class="page-title">Configurações de SLA</h2>
    <p class="text-muted mb-0">Define prazos e notificações por etapa. Escolha, por etapa, entre uma configuração Global (vale pra todas as empresas) ou Individual (cada empresa configura a sua).</p>
  </div>
  <form method="POST" action="/settings/recalculate">
    <button type="submit" class="btn btn-sm btn-outline-warning">
      <i class="bi bi-arrow-clockwise me-1"></i>Reconciliar Status dos Contratos
    </button>
  </form>
</div>

<%
  // Etapas na ordem do fluxo
  const STEP_NAMES = [
    'PROPOSAL_ACCEPTED',
    'CONTRACT_PREPARATION',
    'CONTRACT_SIGNING',
    'CONTRACT_REGISTRATION',
    'CONTRACT_BILLING'
  ];

  // Helper: formata lista de e-mails CSV → um por linha para o textarea
  function fmtEmails(csv) {
    if (!csv) return '';
    return csv.split(',').map(e => e.trim()).filter(Boolean).join('\n');
  }
%>

<div class="accordion" id="slaAccordion">
  <% STEP_NAMES.forEach(function(stepName, idx) {
    const entry       = ruleMap[stepName] || { global: null, byCompany: {} };
    const stepLabel   = h.STEP_LABELS[stepName] || stepName;
    const global      = entry.global;
    const isIndividual = !!(global && global.mode === 'INDIVIDUAL');
  %>
  <div class="accordion-item border mb-2 rounded shadow-sm overflow-hidden">

    <!-- Cabeçalho do accordion -->
    <h2 class="accordion-header">
      <button class="accordion-button collapsed py-3" type="button"
              data-bs-toggle="collapse" data-bs-target="#step-<%= idx %>"
              aria-expanded="false">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <strong><%= stepLabel %></strong>
          <% if (isIndividual) { %>
            <span class="badge bg-info text-white"><i class="bi bi-building me-1"></i>Individual por empresa</span>
          <% } else if (global) { %>
            <span class="badge bg-<%= global.active ? 'success' : 'secondary' %>">
              <%= global.active ? 'Ativo' : 'Inativo' %>
            </span>
            <span class="badge bg-light text-dark border">
              Global: <%= global.businessDays %> dia<%= global.businessDays !== 1 ? 's' : '' %> útil<%= global.businessDays !== 1 ? 'eis' : '' %>
            </span>
            <% if (global.notifyOnNewLead) { %>
              <span class="badge bg-primary text-white"><i class="bi bi-bell-fill me-1"></i>Notifica novo lead</span>
            <% } %>
          <% } %>
        </div>
      </button>
    </h2>

    <!-- Corpo do accordion -->
    <div id="step-<%= idx %>" class="accordion-collapse collapse">
      <div class="accordion-body p-0">

        <!-- Toggle Global / Individual por empresa -->
        <div class="px-3 pt-3 pb-2 bg-light border-bottom">
          <form method="POST" action="/settings/sla/step/<%= stepName %>/mode" class="d-flex align-items-center gap-3 flex-wrap">
            <span class="small fw-semibold text-muted">Configuração:</span>
            <div class="form-check form-check-inline mb-0">
              <input class="form-check-input" type="radio" name="mode" value="GLOBAL" id="mode-global-<%= idx %>"
                     <%= !isIndividual ? 'checked' : '' %> onchange="this.form.submit()" />
              <label class="form-check-label small" for="mode-global-<%= idx %>">Global</label>
            </div>
            <div class="form-check form-check-inline mb-0">
              <input class="form-check-input" type="radio" name="mode" value="INDIVIDUAL" id="mode-individual-<%= idx %>"
                     <%= isIndividual ? 'checked' : '' %> onchange="this.form.submit()" />
              <label class="form-check-label small" for="mode-individual-<%= idx %>">Individual por empresa</label>
            </div>
          </form>
        </div>

        <% if (!isIndividual) { %>
        <!-- ── Configuração Global ────────────────────────────────── -->
        <div class="p-3 bg-light">
          <% if (global) { %>
          <form method="POST" action="/settings/sla/<%= global.id %>">
            <%- include('../partials/sla-rule-fields', { rule: global, hint: 'Aplica-se a todos os contratos, de todas as empresas.' }) %>
          </form>
          <% } else { %>
          <div class="alert alert-warning mb-0">
            <i class="bi bi-exclamation-triangle me-2"></i>Regra global não encontrada para esta etapa. Execute a reconciliação ou contate o suporte.
          </div>
          <% } %>
        </div>
        <% } else { %>
        <!-- ── Abas por Empresa ────────────────────────────────── -->
        <ul class="nav nav-tabs px-3 pt-3 bg-light border-bottom" id="tabs-<%= idx %>" role="tablist">
          <% companies.forEach(function(company, ci) { %>
          <li class="nav-item" role="presentation">
            <button class="nav-link <%= ci === 0 ? 'active' : '' %>" id="tab-<%= idx %>-<%= company.companyId %>-btn"
                    data-bs-toggle="tab" data-bs-target="#tab-<%= idx %>-<%= company.companyId %>"
                    type="button" role="tab">
              <%= company.name %>
              <% const _cr = entry.byCompany[company.companyId];
                 if (_cr && (_cr.notifyEmails || _cr.notifyOnNewLead)) { %>
                <span class="badge bg-success ms-1" title="Configurado com notificações">✓</span>
              <% } else if (_cr) { %>
                <span class="badge bg-secondary ms-1" title="Configurado sem notificações">~</span>
              <% } %>
            </button>
          </li>
          <% }); %>
        </ul>

        <div class="tab-content p-3 bg-light">
          <% companies.forEach(function(company, ci) {
            const companyRule = entry.byCompany[company.companyId] || null;
          %>
          <div class="tab-pane fade <%= ci === 0 ? 'show active' : '' %>" id="tab-<%= idx %>-<%= company.companyId %>" role="tabpanel">
            <% if (companyRule) { %>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="text-muted small"><i class="bi bi-building me-1"></i>Configuração própria de <strong><%= company.name %></strong></span>
              <form method="POST" action="/settings/sla/step/<%= stepName %>/reset"
                    onsubmit="return confirm('Remover a configuração de <%= company.name %> nesta etapa? Ela ficará sem prazo/notificação próprios até ser preenchida novamente.')">
                <input type="hidden" name="companyId" value="<%= company.companyId %>" />
                <button type="submit" class="btn btn-sm btn-outline-danger">
                  <i class="bi bi-trash me-1"></i>Limpar configuração
                </button>
              </form>
            </div>
            <% } else { %>
            <div class="alert alert-info mb-3 small">
              <i class="bi bi-info-circle me-2"></i>
              Nenhuma configuração para <strong><%= company.name %></strong> ainda nesta etapa. Preencha abaixo.
            </div>
            <% } %>
            <form method="POST" action="/settings/sla/step/<%= stepName %>">
              <input type="hidden" name="companyId" value="<%= company.companyId %>" />
              <%- include('../partials/sla-rule-fields', {
                rule: companyRule || { businessDays: 1, active: true, notifyEmails: null, notifyOnNewLead: false },
                hint: 'Configuração própria de ' + company.name + ' — independente da regra Global.'
              }) %>
            </form>
          </div>
          <% }); %>
        </div>
        <% } %>

      </div>
    </div>
  </div>
  <% }); %>
</div>

<!-- ── Notificação de Beneficiários ─────────────────────────────────────── -->
<%
  const beneficiaryGlobal = beneficiaryRuleMap.global;
  const isBenefIndividual = !!(beneficiaryGlobal && beneficiaryGlobal.mode === 'INDIVIDUAL');
%>
<div class="card border mb-3 shadow-sm">
  <div class="card-header bg-white d-flex align-items-center flex-wrap gap-2">
    <strong><i class="bi bi-people-fill me-2"></i>Beneficiários</strong>
    <span class="text-muted small">Quem recebe o pedido de definição de beneficiários PF/PJ antes do envio ao Clicksign</span>
  </div>
  <div class="card-body p-0">

    <!-- Toggle Global / Individual por empresa -->
    <div class="px-3 pt-3 pb-2 bg-light border-bottom">
      <form method="POST" action="/settings/beneficiarios/mode" class="d-flex align-items-center gap-3 flex-wrap">
        <span class="small fw-semibold text-muted">Configuração:</span>
        <div class="form-check form-check-inline mb-0">
          <input class="form-check-input" type="radio" name="mode" value="GLOBAL" id="benef-mode-global"
                 <%= !isBenefIndividual ? 'checked' : '' %> onchange="this.form.submit()" />
          <label class="form-check-label small" for="benef-mode-global">Global</label>
        </div>
        <div class="form-check form-check-inline mb-0">
          <input class="form-check-input" type="radio" name="mode" value="INDIVIDUAL" id="benef-mode-individual"
                 <%= isBenefIndividual ? 'checked' : '' %> onchange="this.form.submit()" />
          <label class="form-check-label small" for="benef-mode-individual">Individual por empresa</label>
        </div>
      </form>
    </div>

    <% if (!isBenefIndividual) { %>
    <div class="p-3 bg-light">
      <form method="POST" action="/settings/beneficiarios">
        <%- include('../partials/beneficiary-rule-fields', {
          rule: beneficiaryGlobal || { notifyEmails: null, active: true },
          hint: 'Aplica-se a todos os contratos, de todas as empresas.'
        }) %>
      </form>
    </div>
    <% } else { %>
    <ul class="nav nav-tabs px-3 pt-3 bg-light border-bottom" id="tabs-beneficiary" role="tablist">
      <% companies.forEach(function(company, ci) { %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= ci === 0 ? 'active' : '' %>" id="tab-beneficiary-<%= company.companyId %>-btn"
                data-bs-toggle="tab" data-bs-target="#tab-beneficiary-<%= company.companyId %>"
                type="button" role="tab">
          <%= company.name %>
          <% if (beneficiaryRuleMap.byCompany[company.companyId]) { %>
            <span class="badge bg-success ms-1" title="Configurado">✓</span>
          <% } %>
        </button>
      </li>
      <% }); %>
    </ul>

    <div class="tab-content p-3 bg-light">
      <% companies.forEach(function(company, ci) {
        const companyRule = beneficiaryRuleMap.byCompany[company.companyId] || null;
      %>
      <div class="tab-pane fade <%= ci === 0 ? 'show active' : '' %>" id="tab-beneficiary-<%= company.companyId %>" role="tabpanel">
        <% if (companyRule) { %>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="text-muted small"><i class="bi bi-building me-1"></i>Configuração própria de <strong><%= company.name %></strong></span>
          <form method="POST" action="/settings/beneficiarios/company/reset"
                onsubmit="return confirm('Remover a configuração de <%= company.name %>? Ela ficará sem destinatário próprio até ser preenchida novamente.')">
            <input type="hidden" name="companyId" value="<%= company.companyId %>" />
            <button type="submit" class="btn btn-sm btn-outline-danger">
              <i class="bi bi-trash me-1"></i>Limpar configuração
            </button>
          </form>
        </div>
        <% } else { %>
        <div class="alert alert-info mb-3 small">
          <i class="bi bi-info-circle me-2"></i>
          Nenhuma configuração para <strong><%= company.name %></strong> ainda. Preencha abaixo.
        </div>
        <% } %>
        <form method="POST" action="/settings/beneficiarios/company">
          <input type="hidden" name="companyId" value="<%= company.companyId %>" />
          <%- include('../partials/beneficiary-rule-fields', {
            rule: companyRule || { notifyEmails: null, active: true },
            hint: 'Configuração própria de ' + company.name + ' — independente da regra Global.'
          }) %>
        </form>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<div class="alert alert-info mt-3 small">
  <i class="bi bi-info-circle me-2"></i>
  <strong>Como funciona:</strong> Cada etapa (e o bloco Beneficiários) tem seu próprio modo — <strong>Global</strong> (padrão: uma única configuração vale pra todas as empresas) ou <strong>Individual por empresa</strong> (cada empresa configura a sua, sem herdar nada da Global).
  Trocar de modo não apaga o que já foi configurado do outro lado — só passa a ignorar até você trocar de volta.
  Os e-mails configurados substituem a variável de ambiente <code>DELAY_NOTIFY_EMAILS</code> quando em modo Global.
  <% if (companies.length === 0) { %>
  <br/><strong class="text-warning">⚠ Nenhuma empresa mapeada nas variáveis de ambiente (PIPEDRIVE_PASCHOINI_COMPANY_ID, PIPEDRIVE_FOCUS_COMPANY_ID, PIPEDRIVE_ATTIVOS_COMPANY_ID).</strong>
  <% } %>
</div>
