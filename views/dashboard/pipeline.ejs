<%
const pipelineSteps = h.STEP_NAMES_ORDERED;
%>
<div class="card mb-4">
  <div class="card-header d-flex align-items-center justify-content-between">
    <span><i class="bi bi-diagram-3 me-2"></i>Contratos por Etapa</span>
    <a href="/contracts" class="btn btn-sm btn-outline-primary">Ver todos</a>
  </div>
  <div class="card-body p-0">
    <div class="pipeline-grid">
      <% pipelineSteps.forEach(function(stepName) {
        const col = summary.pipelineByStep[stepName];
        const count = col ? col.count : 0;
        const contracts = col ? col.contracts : [];
        const hasDelayed = contracts.some(function(c) { return c.overallStatus === 'DELAYED'; });
      %>
      <div class="pipeline-col">
        <div class="pipeline-col-header <%= hasDelayed ? 'has-delayed' : '' %>">
          <span class="pipeline-step-label"><%= h.STEP_LABELS[stepName] %></span>
          <span class="pipeline-count badge <%= count > 0 ? (hasDelayed ? 'bg-danger' : 'bg-primary') : 'bg-secondary' %>">
            <%= count %>
          </span>
        </div>
        <div class="pipeline-col-body">
          <% if (contracts.length === 0) { %>
          <div class="pipeline-empty">
            <i class="bi bi-inbox"></i>
            <span>Nenhum</span>
          </div>
          <% } %>
          <% contracts.forEach(function(c) {
            const isDelayed = c.overallStatus === 'DELAYED';
            const currentStepObj = c.steps.find(function(s) { return s.stepName === stepName; });
            const isOverdue = currentStepObj && currentStepObj.dueAt && new Date(currentStepObj.dueAt) < new Date();
          %>
          <a href="/contracts/<%= c.id %>" class="pipeline-card <%= isDelayed ? 'delayed' : '' %>">
            <div class="pipeline-card-name"><%= c.customer.name %></div>
            <div class="pipeline-card-deal text-truncate"><%= c.pipedriveDeal.title %></div>
            <div class="pipeline-card-footer">
              <span class="pipeline-card-value"><%= h.formatCurrency(c.pipedriveDeal.value) %></span>
              <% if (isDelayed) { %>
              <span class="badge bg-danger" style="font-size:.65rem">
                <i class="bi bi-exclamation-triangle"></i> Atrasado
              </span>
              <% } else if (currentStepObj && currentStepObj.dueAt) { %>
              <span class="pipeline-card-due <%= isOverdue ? 'text-danger' : 'text-muted' %>">
                <i class="bi bi-calendar2 me-1"></i><%= h.formatDate(currentStepObj.dueAt) %>
              </span>
              <% } %>
            </div>
            <% if (c.assignedUser) { %>
            <div class="pipeline-card-user">
              <span class="pipeline-avatar"><%= c.assignedUser.name.charAt(0).toUpperCase() %></span>
              <span class="pipeline-card-username"><%= c.assignedUser.name %></span>
            </div>
            <% } %>
          </a>
          <% }); %>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>
