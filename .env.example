# =============================================================================
# BANCO DE DADOS
# =============================================================================
DATABASE_URL="postgresql://contratos_user:contratos_pass@localhost:5432/contratos_db"

# =============================================================================
# APLICAÇÃO
# =============================================================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# =============================================================================
# AUTENTICAÇÃO
# =============================================================================
JWT_SECRET=troque_por_uma_string_secreta_longa_e_aleatoria_aqui
JWT_EXPIRES_IN=8h
COOKIE_SECRET=troque_por_outro_segredo_para_cookies

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# INTEGRAÇÃO PIPEDRIVE
# =============================================================================
PIPEDRIVE_API_TOKEN=seu_token_aqui
PIPEDRIVE_DOMAIN=sua_empresa.pipedrive.com
# ID do estágio "Proposta aceita" no Pipedrive
PIPEDRIVE_PROPOSAL_ACCEPTED_STAGE_ID=1
PIPEDRIVE_CONTRACT_PREPARATION_STAGE_ID=
# Token secreto para validar webhooks do Pipedrive (configure no painel do Pipedrive)
PIPEDRIVE_WEBHOOK_SECRET=segredo_webhook_pipedrive

# =============================================================================
# INTEGRAÇÃO CLICKSIGN
# =============================================================================
CLICKSIGN_API_KEY=sua_chave_api_aqui
CLICKSIGN_API_URL=https://sandbox.clicksign.com
# Token secreto para validar webhooks da Clicksign
CLICKSIGN_WEBHOOK_TOKEN=segredo_webhook_clicksign

# =============================================================================
# LOGS
# =============================================================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
WEBHOOK_RATE_LIMIT_MAX=200
